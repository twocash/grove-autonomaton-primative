# routing.config
# Maps intents to tiers and zones for this Autonomaton
# Domain: [YOUR DOMAIN HERE]
#
# This is a minimal template. Add your own routes as needed.

# Intent Routing Table
routes:
  # --- System Status Queries (Green Zone) ---
  # These are universal system commands available in all profiles

  dock_status:
    tier: 1
    zone: green
    domain: system
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Vision Board Capture (Sprint 6.5) ---
  vision_capture:
    tier: 1
    zone: green
    domain: system
    description: "Capture aspiration to Vision Board for future skill consideration"
    keywords:
      - "vision board"
      - "i wish"
      - "someday"
      - "it would be cool if"
      - "wouldn't it be nice"
    handler: "vision_capture"
    handler_args: {}

  # --- Session Zero Intake ---
  session_zero:
    tier: 2
    zone: yellow
    domain: system
    description: "Guided Socratic intake to seed entities and business context"
    keywords:
      - "session zero"
      - "run session zero"
      - "start session zero"
      - "intake"
      - "onboarding"
    handler: "session_zero_handler"
    handler_args:
      skill_name: "session-zero-intake"

  # --- Pit Crew (System Self-Modification) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    description: "Build new skill - modifies system capabilities (RED ZONE)"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2

  # =================================================================
  # ADD YOUR DOMAIN-SPECIFIC ROUTES BELOW
  # =================================================================

  # Example route (uncomment and customize):
  # my_custom_intent:
  #   tier: 1
  #   zone: green
  #   domain: my_domain
  #   description: "Description of what this does"
  #   keywords:
  #     - "trigger phrase"
  #     - "another trigger"
  #   handler: "my_handler"
  #   handler_args:
  #     action: "my_action"

# Tier Definitions
tiers:
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
