# routing.config
# Maps intents to tiers and zones for this Autonomaton
# Domain: [YOUR DOMAIN HERE]
#
# Sprint 8: Added intent_type field for Compilation gating and Ratchet data
# - conversational: Skip dock context, no approval needed
# - informational: Optional dock context, typically green zone
# - actionable: Full dock context, zone per config
#
# V-012: Domain handlers live in profiles/handlers.py. This template
# only includes engine-core handlers that work without profile handlers.

# Intent Routing Table
routes:
  # --- Conversational Fallback (Green Zone) ---
  general_chat:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Greetings, acknowledgments, small talk, casual conversation"
    keywords:
      - "hello"
      - "hi"
      - "hey"
      - "how are you"
      - "who are you"
      - "what can you do"
      - "good morning"
      - "good afternoon"
      - "good evening"
      - "my name is"
      - "thanks"
      - "thank you"
      - "bye"
      - "goodbye"
      - "nice to meet you"
      - "what is this"
      - "tell me about yourself"
    handler: "general_chat"
    handler_args: {}

  # --- System Cache Management ---
  clear_cache:
    tier: 1
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Clear the pattern cache (resets the Ratchet)"
    keywords:
      - "clear cache"
      - "reset cache"
      - "reset ratchet"
    handler: "clear_cache"
    handler_args: {}

  # --- System Status Queries (Green Zone) ---
  # These are universal system commands available in all profiles

  dock_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Operator Guide (House Skill) ---
  operator_guide:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Interactive guide explaining how the Autonomaton works"
    keywords:
      - "help"
      - "operator guide"
      - "how does this work"
      - "what can you do"
    handler: "skill_executor"
    handler_args:
      skill_name: "operator-guide"

  # --- Pit Crew (System Self-Modification) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    intent_type: actionable
    description: "Build new skill (RED ZONE). Usage: build skill [name] [description]"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2
      - name: "description"
        position: 3

  # =================================================================
  # ADD YOUR DOMAIN-SPECIFIC ROUTES BELOW
  # =================================================================
  #
  # To add domain handlers, create profiles/your_profile/handlers.py
  # with a register(dispatcher) function that calls:
  #   dispatcher.register_handler("handler_name", handler_function)
  #
  # Example route (uncomment and customize):
  # my_custom_intent:
  #   tier: 1
  #   zone: green
  #   domain: my_domain
  #   intent_type: actionable
  #   description: "Description of what this does"
  #   keywords:
  #     - "trigger phrase"
  #     - "another trigger"
  #   handler: "my_handler"
  #   handler_args:
  #     action: "my_action"

# Tier Definitions
tiers:
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
