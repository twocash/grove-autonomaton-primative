# mcp.config
# Model Context Protocol server configurations
# Domain: [YOUR DOMAIN HERE]

# MCP Server Registry
# Add your MCP server integrations here
servers:
  # Example server (uncomment and customize):
  # my_service:
  #   name: "My Service"
  #   zone: yellow
  #   description: "Description of this service"
  #   capabilities:
  #     - create_record
  #     - update_record
  #     - delete_record
  #   governance:
  #     create_record:
  #       zone: yellow
  #       approval: one_thumb
  #       template: "Create {record_type}: {details}"
  #     delete_record:
  #       zone: red
  #       approval: explicit
  #       template: "Delete {record_type}: {id}"
  #   auth:
  #     type: oauth2
  #     scopes:
  #       - "https://api.myservice.com/scope"
  #   status: stub

# Global MCP Settings
settings:
  default_zone: yellow
  require_audit_log: true
  max_retries: 3
  timeout_seconds: 30
