# routing.config
# Maps intents to tiers and zones for this Autonomaton
# Domain: Reference Implementation (Architecture Demo)
#
# Sprint 8: Added intent_type field for Compilation gating and Ratchet data
# - conversational: Skip dock context, no approval needed
# - informational: Optional dock context, typically green zone
# - actionable: Full dock context, zone per config

# Intent Routing Table
routes:
  # --- Conversational Fallback (Green Zone) ---
  general_chat:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Greetings, acknowledgments, small talk, casual conversation"
    keywords:
      - "hello"
      - "hi"
      - "hey"
      - "how are you"
      - "who are you"
      - "good morning"
      - "good afternoon"
      - "good evening"
      - "my name is"
      - "thanks"
      - "thank you"
      - "bye"
      - "goodbye"
      - "nice to meet you"
      - "tell me about yourself"
    handler: "general_chat"
    handler_args: {}

  # --- Internal System Intents (programmatic, not operator-typed) ---
  welcome_card:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate contextual welcome briefing at startup"
    keywords: []  # No keywords — invoked programmatically only
    handler: "welcome_card"
    handler_args: {}

  startup_brief:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate Chief of Staff strategic brief at startup"
    keywords: []
    handler: "startup_brief"
    handler_args: {}

  generate_plan:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Generate structured plan from dock context (first boot)"
    keywords:
      - "generate plan"
    handler: "generate_plan"
    handler_args: {}

  clear_cache:
    tier: 1
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Clear the pattern cache (resets the Ratchet)"
    keywords:
      - "clear cache"
      - "reset cache"
      - "reset ratchet"
    handler: "clear_cache"
    handler_args: {}

  # --- System Status Queries (Green Zone) ---
  # These are universal system commands available in all profiles

  dock_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Operator Guide (House Skill) ---
  operator_guide:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Interactive guide explaining how the Autonomaton works"
    keywords:
      - "help"
      - "operator guide"
    handler: "skill_executor"
    handler_args:
      skill_name: "operator-guide"

  # --- Architecture Self-Description ---
  explain_system:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Explain the Autonomaton architecture using dock context"
    keywords:
      # --- What is it? ---
      - "what is this"
      - "what does this do"
      - "what is the autonomaton"
      - "what is an autonomaton"
      - "what are you"
      - "what can you do"
      - "tell me about this"
      - "explain"
      - "explain this"
      - "explain the system"
      - "explain the architecture"
      - "how does this work"
      - "how does it work"
      - "how do you work"
      - "walk me through"
      - "give me the overview"
      - "overview"
      - "what am I looking at"
      # --- How is it different? ---
      - "what makes this different"
      - "what makes this special"
      - "what makes it different"
      - "what makes it special"
      - "what's different about this"
      - "how is this different"
      - "how is it different"
      - "how does this differ"
      - "how does it differ"
      - "what's special about"
      - "what's unique about"
      - "what's new here"
      - "why is this different"
      - "how does this compare"
      - "how does it compare"
      - "how is this better"
      - "what's the difference"
      - "what sets this apart"
      - "why is this better"
      - "vs chatbot"
      - "vs a chatbot"
      - "vs agents"
      - "vs an agent"
      - "vs copilot"
      - "vs a copilot"
      - "compared to"
      - "differ from a chatbot"
      - "differ from an agent"
      - "differ from agents"
      - "different from chatgpt"
      - "different from a chatbot"
      - "different from an agent"
      - "isn't this just"
      - "is this just another"
      - "why not just use"
      - "I've seen agents before"
      - "another agent framework"
      - "heard this before"
      - "what's actually new"
      - "convince me"
      # --- Competitive / skeptical ---
      - "compete with"
      - "does this compete"
      - "competing with"
      - "vs openai"
      - "vs anthropic"
      - "vs google"
      - "vs microsoft"
      - "vs langchain"
      - "vs crewai"
      - "vs autogen"
      - "replace openai"
      - "replace anthropic"
      - "need openai"
      - "need anthropic"
      - "need an api"
      - "just use chatgpt"
      - "just use claude"
      - "just use an api"
      - "what about openai"
      - "what about anthropic"
      - "what about langchain"
      - "why not an api"
      - "why not just call"
      - "already have agents"
      - "already have copilot"
      - "we already use"
      - "why do I need this"
      - "do I need this"
      - "what's wrong with"
      - "skeptical"
      - "sounds like hype"
      - "prove it"
      - "show me the value"
      # --- Why should I care? ---
      - "so what"
      - "why does this matter"
      - "why should I care"
      - "what's the point"
      - "why does it matter"
      - "who cares"
      - "what problem does this solve"
      - "what's the big deal"
      # --- Curiosity / follow-up ---
      - "tell me more"
      - "go on"
      - "keep going"
      - "say more"
      - "elaborate"
      - "more detail"
      - "I want to understand"
      - "help me understand"
      - "break it down"
      - "in simple terms"
      - "eli5"
      - "dumb it down"
      # --- Conversational follow-ups ---
      - "ok but"
      - "yeah but"
      - "wait so"
      - "ok so"
      - "and then what"
      - "what happens next"
      - "what else"
      - "what about"
      - "I don't get it"
      - "I don't understand"
      - "say that again"
      - "run that by me again"
      - "huh"
      - "meaning"
      - "what do you mean"
      - "can you clarify"
      - "unpack that"
      - "give me an example"
      - "example"
      - "like what"
      - "such as"
      - "for instance"
      - "use case"
      - "use cases"
      - "who uses this"
      - "who is this for"
      - "real world"
      - "in practice"
      - "concretely"
      - "specifically"
      # --- Architecture specifics ---
      - "what is the pipeline"
      - "what's the pipeline"
      - "what are zones"
      - "what are the zones"
      - "what is the zone model"
      - "what is the ratchet"
      - "what's the ratchet"
      - "what is the flywheel"
      - "what's the flywheel"
      - "what is the skill flywheel"
      - "what is jidoka"
      - "what's jidoka"
      - "what is digital jidoka"
      - "what is the cognitive router"
      - "what are tiers"
      - "what are the tiers"
      - "five stages"
      - "five stage pipeline"
      - "immutable pipeline"
      - "what is telemetry"
      - "what is recognition"
      - "what is compilation"
      - "what is approval"
      - "what is execution"
      - "config over code"
      - "declarative governance"
      # --- Practical ---
      - "how do I use this"
      - "what can I do here"
      - "where do I start"
      - "how do I get started"
      - "what should I try"
      - "show me what it can do"
      - "give me a demo"
    handler: "general_chat"
    handler_args: {}

  # --- Vision Board Capture (Sprint 6.5) ---
  vision_capture:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Capture aspiration to Vision Board for future skill consideration"
    keywords:
      - "vision board"
      - "i wish"
      - "someday"
      - "it would be cool if"
      - "wouldn't it be nice"
    handler: "vision_capture"
    handler_args: {}

  # --- Session Zero Intake ---
  session_zero:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Guided Socratic intake to seed entities and business context"
    keywords:
      - "session zero"
      - "run session zero"
      - "start session zero"
      - "intake"
      - "onboarding"
    handler: "session_zero_handler"
    handler_args:
      skill_name: "session-zero-intake"

  # --- Pit Crew (System Self-Modification) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    intent_type: actionable
    description: "Build new skill (RED ZONE). Usage: build skill [name] [description]"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2
      - name: "description"
        position: 3

  # =================================================================
  # REFERENCE PROFILE: INSPECTION COMMANDS
  # =================================================================

  show_config:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display routing.config contents"
    keywords:
      - "show config"
      - "show routing"
      - "show routes"
    handler: "show_file"
    handler_args:
      target: "config/routing.config"

  show_zones:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display zones.schema contents"
    keywords:
      - "show zones"
      - "show schema"
      - "show governance"
    handler: "show_file"
    handler_args:
      target: "config/zones.schema"

  show_telemetry:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display recent telemetry events"
    keywords:
      - "show telemetry"
      - "show log"
      - "show events"
    handler: "show_file"
    handler_args:
      target: "telemetry/telemetry.jsonl"
      tail: 20

  show_cache:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display pattern cache (the Ratchet)"
    keywords:
      - "show cache"
      - "show ratchet"
      - "show pattern cache"
    handler: "show_file"
    handler_args:
      target: "config/pattern_cache.yaml"

  show_engine:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display engine source file manifest"
    keywords:
      - "show engine"
      - "show source"
      - "show code"
      - "show files"
    handler: "show_engine_manifest"
    handler_args: {}

  # --- Deep Architectural Analysis (Yellow Zone, Apex Tier) ---
  deep_analysis:
    tier: 3
    zone: yellow
    domain: system
    intent_type: informational
    description: "Deep brainstorm on architecture, distributed systems, AI governance"
    keywords:
      - "brainstorm"
      - "go deeper"
      - "deep dive"
      - "let's think about"
      - "distributed vs centralized"
      - "compare architectures"
      - "what makes this different at scale"
      - "why can't centralized systems do this"
      - "the topology problem"
      - "the recursive case"
      - "governance composition"
      - "federation"
      - "peer mesh"
      - "chain composition"
    handler: "strategy_session"
    handler_args: {}

# Tier Definitions
tiers:
  0:
    name: "Deterministic"
    approval: none
    description: "Keyword match, no LLM required"
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"

# Profile Settings
settings:
  # Smart clarification uses LLM to generate context-aware options
  # when Jidoka fires. Costs money (T2 call per ambiguous input).
  # Set to false for demo profiles — use free clarification.yaml
  # options instead. The operator is never surprised by a bill.
  smart_clarification: false
