# routing.config
# Maps intents to tiers and zones for this Autonomaton
# Domain: Reference Implementation (Architecture Demo)
#
# Sprint 8: Added intent_type field for Compilation gating and Ratchet data
# - conversational: Skip dock context, no approval needed
# - informational: Optional dock context, typically green zone
# - actionable: Full dock context, zone per config

# Intent Routing Table
routes:
  # --- Conversational Fallback (Green Zone) ---
  general_chat:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Greetings, acknowledgments, small talk, casual conversation"
    keywords:
      - "hello"
      - "hi"
      - "hey"
      - "how are you"
      - "who are you"
      - "what can you do"
      - "good morning"
      - "good afternoon"
    handler: "general_chat"
    handler_args: {}

  # --- Internal System Intents (programmatic, not operator-typed) ---
  welcome_card:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate contextual welcome briefing at startup"
    keywords: []  # No keywords — invoked programmatically only
    handler: "welcome_card"
    handler_args: {}

  startup_brief:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate Chief of Staff strategic brief at startup"
    keywords: []
    handler: "startup_brief"
    handler_args: {}

  generate_plan:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Generate structured plan from dock context (first boot)"
    keywords:
      - "generate plan"
    handler: "generate_plan"
    handler_args: {}

  clear_cache:
    tier: 1
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Clear the pattern cache (resets the Ratchet)"
    keywords:
      - "clear cache"
      - "reset cache"
      - "reset ratchet"
    handler: "clear_cache"
    handler_args: {}

  # --- System Status Queries (Green Zone) ---
  # These are universal system commands available in all profiles

  dock_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Operator Guide (House Skill) ---
  operator_guide:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Interactive guide explaining how the Autonomaton works"
    keywords:
      - "help"
      - "operator guide"
      - "how does this work"
      - "what can you do"
    handler: "skill_executor"
    handler_args:
      skill_name: "operator-guide"

  # --- Vision Board Capture (Sprint 6.5) ---
  vision_capture:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Capture aspiration to Vision Board for future skill consideration"
    keywords:
      - "vision board"
      - "i wish"
      - "someday"
      - "it would be cool if"
      - "wouldn't it be nice"
    handler: "vision_capture"
    handler_args: {}

  # --- Session Zero Intake ---
  session_zero:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Guided Socratic intake to seed entities and business context"
    keywords:
      - "session zero"
      - "run session zero"
      - "start session zero"
      - "intake"
      - "onboarding"
    handler: "session_zero_handler"
    handler_args:
      skill_name: "session-zero-intake"

  # --- Pit Crew (System Self-Modification) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    intent_type: actionable
    description: "Build new skill - modifies system capabilities (RED ZONE)"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2

  # =================================================================
  # REFERENCE PROFILE: INSPECTION COMMANDS
  # =================================================================

  show_config:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display routing.config contents"
    keywords:
      - "show config"
      - "show routing"
      - "show routes"
    handler: "show_file"
    handler_args:
      target: "config/routing.config"

  show_zones:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display zones.schema contents"
    keywords:
      - "show zones"
      - "show schema"
      - "show governance"
    handler: "show_file"
    handler_args:
      target: "config/zones.schema"

  show_telemetry:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display recent telemetry events"
    keywords:
      - "show telemetry"
      - "show log"
      - "show events"
    handler: "show_file"
    handler_args:
      target: "telemetry/telemetry.jsonl"
      tail: 20

  show_cache:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display pattern cache (the Ratchet)"
    keywords:
      - "show cache"
      - "show ratchet"
      - "show pattern cache"
    handler: "show_file"
    handler_args:
      target: "config/pattern_cache.yaml"

  show_engine:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display engine source file manifest"
    keywords:
      - "show engine"
      - "show source"
      - "show code"
      - "show files"
    handler: "show_engine_manifest"
    handler_args: {}

# Tier Definitions
tiers:
  0:
    name: "Deterministic"
    approval: none
    description: "Keyword match, no LLM required"
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
