# ============================================================
# routing.config — The Cognitive Router's Brain
# ============================================================
# This file IS the Cognitive Router. The engine reads it and
# does exactly what it says. Change this file, change the
# behavior. No deploy required.
#
# A reviewer reads this file and knows:
# - What inputs the system recognizes (routes)
# - How it matches input to intent (router.matching)
# - What counts as a confident match (router.matching.min_confidence)
# - What happens when there's no match (Stage 4 Jidoka)
# - What zone governs each action (route.zone)
# - What handler executes each action (route.handler)
# ============================================================


# ------------------------------------------------------------
# ROUTER CONFIGURATION
# ------------------------------------------------------------
# These settings control how the Cognitive Router classifies
# operator input. All matching logic is driven by this section.
# The Python engine is a generic lookup — it reads these rules
# and follows them.

router:

  # Matching strategy. Determines how input is compared to keywords.
  # Currently supported: "keyword"
  # Future: "semantic", "fuzzy", "hybrid"
  strategy: keyword

  matching:
    # Confidence assigned to each match type.
    # The router tries each type in order (exact → prefix → contains)
    # and returns the highest-confidence match.
    confidence:
      exact: 1.0        # Input exactly equals a keyword
      prefix: 0.9       # Input starts with a keyword
      contains: 0.5     # Input contains a keyword somewhere

    # Minimum confidence to count as a recognized intent.
    # Below this threshold, the router returns intent: unknown
    # and Stage 4 (Jidoka) handles it.
    min_confidence: 0.7

    # Keywords shorter than this character count require word-boundary
    # matching to prevent false positives (e.g., "hi" inside "nothing").
    # Set to 0 to disable word-boundary checking entirely.
    word_boundary_min_length: 4


# ------------------------------------------------------------
# PATTERN CACHE (THE RATCHET)
# ------------------------------------------------------------
# Controls how the Ratchet stores and retrieves confirmed
# LLM classifications. The cache is checked before keyword
# matching — Tier 0, zero cost, instant.

cache:
  enabled: true

  # How many successful executions before a cached classification
  # is considered "established" (affects confidence scoring).
  established_threshold: 3

  # Base confidence for a cache hit. Increases by confidence_increment
  # per confirmation, capped at max_confidence.
  base_confidence: 0.75
  confidence_increment: 0.05
  max_confidence: 0.99


# ------------------------------------------------------------
# ROUTES
# ------------------------------------------------------------
# Each route maps an intent to a tier, zone, handler, and
# keyword list. The router matches operator input against
# keywords and returns the route with the highest confidence.
#
# Fields:
#   tier:         Compute tier (0=cache, 1=keyword, 2=supervised, 3=apex)
#   zone:         Governance zone (green/yellow/red)
#   domain:       Business domain for zone schema lookup
#   intent_type:  conversational | informational | actionable
#   description:  Human-readable (also sent to LLM for classification)
#   keywords:     List of matching keywords/phrases
#   handler:      Dispatcher handler name
#   handler_args: Static arguments passed to the handler

routes:

  # --- Conversational (Green Zone, Tier 1) ---
  general_chat:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Greetings, acknowledgments, small talk"
    keywords:
      - "hello"
      - "hi"
      - "hey"
      - "how are you"
      - "who are you"
      - "good morning"
      - "good afternoon"
      - "good evening"
      - "thanks"
      - "thank you"
      - "bye"
      - "goodbye"
    handler: "general_chat"

  # --- Architecture Self-Description (Green Zone, Tier 1) ---
  # DELIBERATELY STRIPPED per V-002. Core architectural terms only.
  # General curiosity ("how is this different from a chatbot?") SHOULD
  # hit Jidoka → Kaizen, demonstrating the consent flow for reviewers.
  # The reference profile WANTS reviewers to see the Kaizen prompt.
  explain_system:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Explain the Autonomaton architecture using dock context"
    keywords:
      - "what is this"
      - "what is the autonomaton"
      - "what is an autonomaton"
      - "how does this work"
      - "pipeline"
      - "zones"
      - "zone model"
      - "ratchet"
      - "flywheel"
      - "skill flywheel"
      - "jidoka"
      - "digital jidoka"
      - "cognitive router"
      - "tiers"
      - "five stages"
      - "telemetry"
      - "config over code"
      - "declarative governance"
    handler: "general_chat"

  # --- System Status Queries (Green Zone, Tier 1) ---
  dock_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Cache Management (Yellow Zone) ---
  clear_cache:
    tier: 1
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Clear the pattern cache (resets the Ratchet)"
    keywords:
      - "clear cache"
      - "reset cache"
      - "reset ratchet"
    handler: "clear_cache"

  # --- Deep Analysis (Yellow Zone, Tier 3) ---
  deep_analysis:
    tier: 3
    zone: yellow
    domain: system
    intent_type: informational
    description: "Explicit brainstorm or deep analysis request"
    keywords:
      - "brainstorm"
      - "go deeper"
      - "deep dive"
      - "strategy session"
    handler: "strategy_session"

  # --- Pit Crew (Red Zone, Tier 3) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    intent_type: actionable
    description: "Build new skill (RED ZONE). Usage: build skill [name] [description]"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"

  # --- Reference Profile: Inspection Commands (Green Zone, Tier 0) ---
  show_config:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display routing.config contents"
    keywords:
      - "show config"
      - "show routing"
      - "show routes"
    handler: "show_file"
    handler_args:
      target: "config/routing.config"

  show_zones:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display zones.schema contents"
    keywords:
      - "show zones"
      - "show schema"
      - "show governance"
    handler: "show_file"
    handler_args:
      target: "config/zones.schema"

  show_telemetry:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display recent telemetry events"
    keywords:
      - "show telemetry"
      - "show log"
      - "show events"
    handler: "show_file"
    handler_args:
      target: "telemetry/telemetry.jsonl"
      tail: 20

  show_cache:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display pattern cache (the Ratchet)"
    keywords:
      - "show cache"
      - "show ratchet"
      - "show pattern cache"
    handler: "show_file"
    handler_args:
      target: "config/pattern_cache.yaml"

  show_engine:
    tier: 0
    zone: green
    domain: system
    intent_type: informational
    description: "Display engine source file manifest"
    keywords:
      - "show engine"
      - "show source"
      - "show code"
    handler: "show_engine_manifest"


# ------------------------------------------------------------
# TIER DEFINITIONS
# ------------------------------------------------------------
tiers:
  0:
    name: "Pattern Cache"
    description: "Cached classification, no model call, zero cost"
  1:
    name: "Keyword Match"
    description: "Config-driven lookup, no model call, zero cost"
  2:
    name: "Supervised"
    description: "LLM classification with operator consent"
  3:
    name: "Apex"
    description: "Frontier model, maximum capability, maximum cost"
