# mcp.config
# Model Context Protocol server configurations
# Domain: Catholic High School Golf Coach

# MCP Server Registry
servers:
  google_calendar:
    name: "Google Calendar"
    zone: yellow
    description: "Schedule lessons, practices, and tournaments"
    capabilities:
      - create_event
      - update_event
      - delete_event
      - list_events
    governance:
      create_event:
        zone: yellow
        approval: one_thumb
        template: "Schedule {event_type} for {participant} on {date}"
      update_event:
        zone: yellow
        approval: one_thumb
        template: "Update {event_id}: {change_summary}"
      delete_event:
        zone: red
        approval: explicit
        template: "Delete event: {event_title} on {date}"
      list_events:
        zone: green
        approval: none
    auth:
      type: oauth2
      scopes:
        - "https://www.googleapis.com/auth/calendar"
    status: stub

  gmail:
    name: "Gmail"
    zone: yellow
    description: "Email parents and coordinate with venues"
    capabilities:
      - send_email
      - draft_email
      - read_email
      - list_threads
    governance:
      send_email:
        zone: yellow
        approval: one_thumb
        template: "Send email to {recipient}: {subject}"
      draft_email:
        zone: green
        approval: none
        template: "Draft email to {recipient}"
      read_email:
        zone: green
        approval: none
      list_threads:
        zone: green
        approval: none
    auth:
      type: oauth2
      scopes:
        - "https://www.googleapis.com/auth/gmail.modify"
    status: stub

# Future MCP Servers (Planned)
planned:
  stripe:
    name: "Stripe Payments"
    zone: red
    description: "Process lesson payments"
    status: not_implemented

  weather_api:
    name: "Weather API"
    zone: green
    description: "Check conditions for practice planning"
    status: not_implemented

# Global MCP Settings
settings:
  default_zone: yellow
  require_audit_log: true
  max_retries: 3
  timeout_seconds: 30
