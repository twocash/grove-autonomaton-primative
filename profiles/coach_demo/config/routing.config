# routing.config
# Maps intents to tiers and zones for The Coach Autonomaton
# Domain: Catholic High School Golf Coach

# Intent Routing Table
routes:
  # --- Content Generation ---
  weekly_session:
    tier: 1
    zone: green
    domain: lessons
    description: "Generate weekly practice session plan"

  content_draft:
    tier: 1
    zone: green
    domain: content
    description: "Draft social media content from pillars"

  content_compilation:
    tier: 2
    zone: yellow
    domain: content
    description: "Compile content seeds into platform-ready drafts (writes to output/)"

  # --- Entity Management ---
  entity_validation:
    tier: 2
    zone: yellow
    domain: players
    description: "Validate or resolve player/parent entities"

  roster_update:
    tier: 2
    zone: yellow
    domain: players
    description: "Modify team roster data"

  # --- Financial Operations ---
  payment_reminder:
    tier: 3
    zone: yellow
    domain: money
    description: "Send payment reminder to parent"

  fee_adjustment:
    tier: 3
    zone: red
    domain: money
    description: "Adjust lesson fees or payment terms"

  # --- System Self-Modification (Pit Crew) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    description: "Build new skill - modifies system capabilities (RED ZONE)"

  # --- External Communications ---
  calendar_schedule:
    tier: 2
    zone: yellow
    domain: lessons
    description: "Schedule lesson on Google Calendar"

  email_parent:
    tier: 2
    zone: yellow
    domain: parents
    description: "Send email to parent via Gmail"

  # --- Analytics ---
  performance_report:
    tier: 1
    zone: green
    domain: analytics
    description: "Generate player performance summary"

# Tier Definitions
tiers:
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
