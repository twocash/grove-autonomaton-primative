# routing.config
# Maps intents to tiers and zones for The Coach Autonomaton
# Domain: Catholic High School Golf Coach
#
# Sprint 1: Added keywords and handlers for Cognitive Router

# Intent Routing Table
routes:
  # --- Status Queries (Green Zone) ---
  dock_status:
    tier: 1
    zone: green
    domain: system
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Operator Guide (House Skill) ---
  operator_guide:
    tier: 1
    zone: green
    domain: system
    description: "Interactive guide explaining how the Autonomaton works"
    keywords:
      - "help"
      - "operator guide"
      - "how does this work"
      - "what can you do"
    handler: "skill_executor"
    handler_args:
      skill_name: "operator-guide"

  # --- Vision Board Capture (Sprint 6.5) ---
  vision_capture:
    tier: 1
    zone: green
    domain: system
    description: "Capture aspiration to Vision Board for future skill consideration"
    keywords:
      - "vision board"
      - "i wish"
      - "someday"
      - "it would be cool if"
      - "wouldn't it be nice"
    handler: "vision_capture"
    handler_args: {}

  # --- Session Zero Intake (Sprint 1.5) ---
  session_zero:
    tier: 2
    zone: yellow
    domain: system
    description: "Guided Socratic intake to seed entities and business context"
    keywords:
      - "session zero"
      - "run session zero"
      - "start session zero"
      - "intake"
      - "onboarding"
    handler: "session_zero_handler"
    handler_args:
      skill_name: "session-zero-intake"

  # --- Content Generation ---
  weekly_session:
    tier: 1
    zone: green
    domain: lessons
    description: "Generate weekly practice session plan"
    keywords:
      - "weekly session"
      - "practice plan"
      - "weekly practice"

  content_draft:
    tier: 1
    zone: green
    domain: content
    description: "Draft social media content from pillars"
    keywords:
      - "draft content"
      - "content draft"

  content_compilation:
    tier: 2
    zone: yellow
    domain: content
    description: "Compile content seeds into platform-ready drafts (writes to output/)"
    keywords:
      - "compile content"
      - "compile"
      - "content compilation"
    handler: "content_engine"
    handler_args:
      action: "compile"

  # --- Entity Management ---
  entity_validation:
    tier: 2
    zone: yellow
    domain: players
    description: "Validate or resolve player/parent entities"
    keywords:
      - "validate entity"
      - "resolve entity"

  roster_update:
    tier: 2
    zone: yellow
    domain: players
    description: "Modify team roster data"
    keywords:
      - "update roster"
      - "roster update"
      - "modify roster"

  # --- Financial Operations ---
  payment_reminder:
    tier: 3
    zone: yellow
    domain: money
    description: "Send payment reminder to parent"
    keywords:
      - "payment reminder"
      - "remind payment"

  fee_adjustment:
    tier: 3
    zone: red
    domain: money
    description: "Adjust lesson fees or payment terms"
    keywords:
      - "adjust fee"
      - "fee adjustment"
      - "change fee"

  # --- System Self-Modification (Pit Crew) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    description: "Build new skill - modifies system capabilities (RED ZONE)"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2

  # --- External Communications (MCP Actions) ---
  calendar_schedule:
    tier: 2
    zone: yellow
    domain: lessons
    description: "Schedule lesson on Google Calendar"
    keywords:
      - "schedule lesson"
      - "schedule a lesson"
      - "calendar"
      - "add to calendar"
      - "book lesson"
    handler: "mcp_calendar"
    handler_args:
      server: "google_calendar"
      capability: "create_event"
    mcp_payload_schema:
      - participant
      - date
      - time
      - duration_minutes
      - location

  email_parent:
    tier: 2
    zone: yellow
    domain: players
    description: "Send email to parent via Gmail"
    keywords:
      - "email parent"
      - "send email"
      - "email"
      - "message parent"
    handler: "mcp_gmail"
    handler_args:
      server: "gmail"
      capability: "send_email"
    mcp_payload_schema:
      - recipient
      - subject
      - body

  # --- Analytics ---
  performance_report:
    tier: 1
    zone: green
    domain: analytics
    description: "Generate player performance summary"
    keywords:
      - "performance report"
      - "player report"
      - "progress report"

  # --- Cortex Batch Analysis (Sprint 5) ---
  cortex_analyze:
    tier: 2
    zone: yellow
    domain: system
    description: "Lens 3: Pattern analysis - identify workflow gaps via telemetry cross-reference"
    keywords:
      - "cortex analyze"
      - "cortex analysis"
      - "analyze patterns"
      - "pattern analysis"
    handler: "cortex_batch"
    handler_args:
      lens: "pattern_analysis"

  cortex_ratchet:
    tier: 2
    zone: yellow
    domain: system
    description: "Lens 4: Ratchet analysis - propose tier demotions for stable patterns"
    keywords:
      - "cortex ratchet"
      - "ratchet analysis"
      - "tier demotion"
      - "cost optimization"
    handler: "cortex_batch"
    handler_args:
      lens: "ratchet_analysis"

  cortex_evolve:
    tier: 2
    zone: yellow
    domain: system
    description: "Lens 5: Evolution - propose new skills based on telemetry and exhaust board"
    keywords:
      - "cortex evolve"
      - "cortex evolution"
      - "evolve system"
      - "suggest skills"
      - "propose skill"
    handler: "cortex_batch"
    handler_args:
      lens: "evolution_analysis"

# Tier Definitions
tiers:
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
