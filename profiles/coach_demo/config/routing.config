# routing.config
# Maps intents to tiers and zones for The Coach Autonomaton
# Domain: Catholic High School Golf Coach
#
# Sprint 8: Added intent_type field for Compilation gating and Ratchet data
# - conversational: Skip dock context, no approval needed
# - informational: Optional dock context, typically green zone
# - actionable: Full dock context, zone per config

# Intent Routing Table
routes:
  # --- Conversational (Green Zone, No Dock Context) ---
  general_chat:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Greetings, acknowledgments, small talk, casual conversation"
    keywords:
      - "hello"
      - "hi"
      - "hey"
      - "how are you"
      - "who are you"
      - "what can you do"
      - "good morning"
      - "good afternoon"
    handler: "general_chat"
    handler_args: {}

  # --- Internal System Intents (programmatic, not operator-typed) ---
  welcome_card:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate contextual welcome briefing at startup"
    keywords: []  # No keywords — invoked programmatically only
    handler: "welcome_card"
    handler_args: {}

  startup_brief:
    tier: 2
    zone: green
    domain: system
    intent_type: informational
    description: "Generate Chief of Staff strategic brief at startup"
    keywords: []
    handler: "startup_brief"
    handler_args: {}

  generate_plan:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Generate structured plan from dock context (first boot)"
    keywords:
      - "generate plan"
    handler: "generate_plan"
    handler_args: {}

  clear_cache:
    tier: 1
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Clear the pattern cache (resets the Ratchet)"
    keywords:
      - "clear cache"
      - "reset cache"
      - "reset ratchet"
    handler: "clear_cache"
    handler_args: {}

  # --- Informational Queries (Green Zone) ---
  dock_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display dock status and loaded sources"
    keywords:
      - "dock"
      - "dock status"
    handler: "status_display"
    handler_args:
      display_type: "dock"

  queue_status:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Display Kaizen queue status"
    keywords:
      - "queue"
      - "kaizen queue"
      - "pending"
    handler: "status_display"
    handler_args:
      display_type: "queue"

  skills_list:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "List deployed skills"
    keywords:
      - "skills"
      - "list skills"
      - "deployed skills"
    handler: "status_display"
    handler_args:
      display_type: "skills"

  # --- Operator Guide (House Skill) ---
  operator_guide:
    tier: 1
    zone: green
    domain: system
    intent_type: informational
    description: "Interactive guide explaining how the Autonomaton works"
    keywords:
      - "help"
      - "operator guide"
      - "how does this work"
      - "what can you do"
    handler: "skill_executor"
    handler_args:
      skill_name: "operator-guide"

  # --- Strategy Session (Active Work Requests) ---
  strategy_session:
    tier: 2    # Upgraded — synthesis needs Sonnet
    zone: green
    domain: system
    intent_type: actionable
    description: "When the user wants to know what to work on, check priorities, plan their day, get a status overview, or ask what matters right now. Covers informal check-ins like 'what's on tap', 'where should I start', 'catch me up', 'what's the plan'."
    keywords:
      - "work on my goals"
      - "work on goals"
      - "review goals"
      - "what should i do"
      - "what's next"
      - "next steps"
      - "review my plan"
      - "review business plan"
      - "what should i focus on"
      - "priorities"
    handler: "strategy_session"
    handler_args: {}

  # --- Tournament Prep (Opening Day Sprint) ---
  tournament_prep:
    tier: 2
    zone: green
    domain: lessons
    intent_type: actionable
    description: "Generate pre-tournament preparation package with lineup, scouting cards, course strategy, and pregame message"
    keywords:
      - "tournament prep"
      - "match prep"
      - "prepare for match"
      - "get ready for"
      - "prep for cathedral"
      - "lineup"
    handler: "skill_executor"
    handler_args:
      skill_name: "tournament-prep"

  # --- Vision Board Capture (Sprint 6.5) ---
  vision_capture:
    tier: 1
    zone: green
    domain: system
    intent_type: conversational
    description: "Capture aspiration to Vision Board for future skill consideration"
    keywords:
      - "vision board"
      - "i wish"
      - "someday"
      - "it would be cool if"
      - "wouldn't it be nice"
    handler: "vision_capture"
    handler_args: {}

  # --- Session Zero Intake (Sprint 1.5) ---
  session_zero:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Guided Socratic intake to seed entities and business context"
    keywords:
      - "session zero"
      - "run session zero"
      - "start session zero"
      - "intake"
      - "onboarding"
    handler: "session_zero_handler"
    handler_args:
      skill_name: "session-zero-intake"

  # --- Content Generation ---
  weekly_session:
    tier: 1
    zone: green
    domain: lessons
    intent_type: actionable
    description: "Generate weekly practice session plan"
    keywords:
      - "weekly session"
      - "practice plan"
      - "weekly practice"

  content_draft:
    tier: 1
    zone: green
    domain: content
    intent_type: actionable
    description: "Draft social media content from pillars"
    keywords:
      - "draft content"
      - "content draft"

  content_compilation:
    tier: 2
    zone: yellow
    domain: content
    intent_type: actionable
    description: "Compile content seeds into platform-ready drafts (writes to output/)"
    keywords:
      - "compile content"
      - "compile"
      - "content compilation"
    handler: "content_engine"
    handler_args:
      action: "compile"

  # --- Entity Management ---
  entity_validation:
    tier: 2
    zone: yellow
    domain: players
    intent_type: actionable
    description: "Validate or resolve player/parent entities"
    keywords:
      - "validate entity"
      - "resolve entity"

  roster_update:
    tier: 2
    zone: yellow
    domain: players
    intent_type: actionable
    description: "Modify team roster data"
    keywords:
      - "update roster"
      - "roster update"
      - "modify roster"

  # --- Financial Operations ---
  payment_reminder:
    tier: 3
    zone: yellow
    domain: money
    intent_type: actionable
    description: "Send payment reminder to parent"
    keywords:
      - "payment reminder"
      - "remind payment"

  fee_adjustment:
    tier: 3
    zone: red
    domain: money
    intent_type: actionable
    description: "Adjust lesson fees or payment terms"
    keywords:
      - "adjust fee"
      - "fee adjustment"
      - "change fee"

  # --- System Self-Modification (Pit Crew) ---
  pit_crew_build:
    tier: 3
    zone: red
    domain: system
    intent_type: actionable
    description: "Build new skill - modifies system capabilities (RED ZONE)"
    keywords:
      - "build skill"
    handler: "pit_crew"
    handler_args:
      action: "build"
    extract_args:
      - name: "skill_name"
        position: 2

  # --- External Communications (MCP Actions) ---
  calendar_schedule:
    tier: 2
    zone: yellow
    domain: lessons
    intent_type: actionable
    description: "Schedule lesson on Google Calendar"
    keywords:
      - "schedule lesson"
      - "schedule a lesson"
      - "calendar"
      - "add to calendar"
      - "book lesson"
    handler: "mcp_calendar"
    handler_args:
      server: "google_calendar"
      capability: "create_event"
    mcp_payload_schema:
      - participant
      - date
      - time
      - duration_minutes
      - location

  email_parent:
    tier: 2
    zone: yellow
    domain: players
    intent_type: actionable
    description: "Send email to parent via Gmail"
    keywords:
      - "email parent"
      - "send email"
      - "email"
      - "message parent"
    handler: "mcp_gmail"
    handler_args:
      server: "gmail"
      capability: "send_email"
    mcp_payload_schema:
      - recipient
      - subject
      - body

  # --- Analytics ---
  performance_report:
    tier: 1
    zone: green
    domain: analytics
    intent_type: informational
    description: "Generate player performance summary"
    keywords:
      - "performance report"
      - "player report"
      - "progress report"

  # --- Cortex Batch Analysis (Sprint 5) ---
  cortex_analyze:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Lens 3: Pattern analysis - identify workflow gaps via telemetry cross-reference"
    keywords:
      - "cortex analyze"
      - "cortex analysis"
      - "analyze patterns"
      - "pattern analysis"
    handler: "cortex_batch"
    handler_args:
      lens: "pattern_analysis"

  cortex_ratchet:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Lens 4: Ratchet analysis - propose tier demotions for stable patterns"
    keywords:
      - "cortex ratchet"
      - "ratchet analysis"
      - "tier demotion"
      - "cost optimization"
    handler: "cortex_batch"
    handler_args:
      lens: "ratchet_analysis"

  cortex_evolve:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Lens 5: Evolution - propose new skills based on telemetry and exhaust board"
    keywords:
      - "cortex evolve"
      - "cortex evolution"
      - "evolve system"
      - "suggest skills"
      - "propose skill"
    handler: "cortex_batch"
    handler_args:
      lens: "evolution_analysis"

  # --- Structured Plan Management (Sprint 5) ---
  plan_update:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Update structured plan - writes to dock (YELLOW ZONE)"
    keywords:
      - "update plan"
      - "update the plan"
      - "plan update"
      - "modify plan"
    handler: "plan_update"
    handler_args: {}

  regenerate_plan:
    tier: 2
    zone: yellow
    domain: system
    intent_type: actionable
    description: "Regenerate full structured plan from current state"
    keywords:
      - "regenerate plan"
      - "refresh plan"
      - "rebuild plan"
      - "update the full plan"
    handler: "regenerate_plan"
    handler_args: {}

  # --- Entity Gap Filling (Sprint 5) ---
  fill_entity_gap:
    tier: 2
    zone: yellow
    domain: entities
    intent_type: actionable
    description: "Add missing information to an entity profile"
    keywords:
      - "add email for"
      - "update email for"
      - "email for"
      - "add phone for"
      - "add handicap for"
      - "add contact for"
      - "fill in"
      - "update contact"
    handler: "fill_entity_gap"
    handler_args: {}

  # --- Ratchet Classification Sub-Intents (Sprint 6 - ADR-001) ---
  # These are the interpret layer for ratchet_classify() pipeline traversals.
  # The Cognitive Router owns classification; these routes enable LLM fallback.

  ratchet_intent_classify:
    tier: 2
    zone: green
    domain: system
    intent_type: actionable
    description: "LLM interpret layer for intent classification ratchet"
    handler: "ratchet_interpreter"
    handler_args:
      classifier: "intent"
      prompt_template: "classify_intent"

  ratchet_entity_extract:
    tier: 1
    zone: green
    domain: system
    intent_type: actionable
    description: "LLM interpret layer for entity extraction ratchet"
    handler: "ratchet_interpreter"
    handler_args:
      classifier: "entity_extraction"
      prompt_template: "extract_entities"

  ratchet_correction_detect:
    tier: 1
    zone: green
    domain: system
    intent_type: actionable
    description: "LLM interpret layer for correction detection ratchet (Memory Accumulator)"
    handler: "ratchet_interpreter"
    handler_args:
      classifier: "correction_detection"
      prompt_template: "detect_correction"

  ratchet_gap_detect:
    tier: 1
    zone: green
    domain: system
    intent_type: actionable
    description: "LLM interpret layer for gap detection ratchet"
    handler: "ratchet_interpreter"
    handler_args:
      classifier: "gap_detection"
      prompt_template: "detect_gap"

# Tier Definitions
tiers:
  1:
    name: "Autonomous"
    approval: none
    description: "Safe operations, no approval required"
  2:
    name: "Supervised"
    approval: one_thumb
    description: "Requires single confirmation"
  3:
    name: "Restricted"
    approval: explicit
    description: "Requires explicit approval with context"
